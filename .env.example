# Copia este archivo a ".env" y rellena tus valores.

# Connection string de PostgreSQL. Crea una base GRATIS en:
#   https://neon.tech   o   https://supabase.com
# Se ve algo así (Neon ya incluye ?sslmode=require):
DATABASE_URL=postgresql://usuario:password@host/dbname?sslmode=require

# Cada cuántos minutos hacer ping (opcional, por defecto 2)
INTERVAL_MINUTES=2

# Timeout por petición en segundos (opcional, por defecto 30)
TIMEOUT_SECONDS=30

# Puerto del health server. Solo necesario si lo subes a un host en la nube
# (Render/Koyeb). En tu PC déjalo sin definir.
# PORT=3000

# AUTO-PING: URL pública de ESTE server para que se pinguee a sí mismo y no se
# duerma. DEBE ser la url pública (https://...), NO localhost.
# En Render NO hace falta: usa RENDER_EXTERNAL_URL automáticamente.
# En otros hosts, descomenta y pon tu url:
# SELF_URL=https://tu-app.onrender.com
